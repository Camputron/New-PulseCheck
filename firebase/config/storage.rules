rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // PDFs and text files uploaded by poll creators for AI question generation.
    // @see src/components/poll/edit/UploadPDFDialog.tsx
    match /ai/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        // ensure file size is <= 100 MB
        && request.resource.size < 100 * 1024 * 1024
        && (
          request.resource.contentType == 'application/pdf'
          || request.resource.contentType.matches('text/.*')
        );
    }

    // Question images embedded in polls. Reads are public because rendered
    // <img> tags fire from any session participant (incl. anonymous guests);
    // the download URLs already carry access tokens.
    // @see src/components/poll/edit/question/UploadImageBox.tsx
    match /poll-images/{filename} {
      allow read: if true;
      allow write: if request.auth != null
        // ensure file size is <= 100 MB
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Default deny.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
